{
  "expo": {
    "name": "DayWiggle",
    "slug": "daywiggle-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "daywiggle",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}